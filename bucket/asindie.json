{
  "version": "0.6.0",
  "description": "AsIndie game distribution CLI",
  "homepage": "https://asindie.com",
  "license": "Apache-2.0",
  "architecture": {
    "64bit": {
      "url": "https://releases.asindie.com/cli/0.6.0/asindie-windows-x64.exe",
      "hash": "26169f31dfa87e1346a641ce98ec8264ead0a994b2641714361db4ace6964c18"
    }
  },
  "bin": "asindie.exe",
  "checkver": {
    "url": "https://releases.asindie.com/cli/latest.json",
    "jsonpath": "$.version"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://releases.asindie.com/cli/$version/asindie-windows-x64.exe"
      }
    },
    "hash": {
      "url": "https://releases.asindie.com/cli/$version/manifest.json",
      "jsonpath": "$.assets.\"windows-x64\".sha256"
    }
  },
  "pre_install": [
    "Rename-Item \"$dir\\asindie-windows-x64.exe\" \"asindie.exe\""
  ]
}
